# ─────────────────────────────────────────────────────────────

# Scholar SMS — Environment Variables (Example)

# Copy this file → rename to .env and fill your actual values

# ⚠️ Do NOT commit your real .env file to GitHub

# ─────────────────────────────────────────────────────────────

# 🌐 Server Configuration

PORT=5004

# 🗄️ MongoDB Connection URI

# 👉 Local MongoDB (recommended for development)

MONGO_URI=mongodb://127.0.0.1:27017/scholar_sms

# 👉 OR MongoDB Atlas (cloud setup)

# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/scholar_sms

# 🔐 JWT Configuration

# Secret key for signing tokens (change this in production)

JWT_SECRET=your_super_secret_key_here

# Token expiry duration

JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────

# 📌 Usage:

# 1. Copy → cp .env.example .env

# 2. Fill values if needed

# 3. Run backend → node server.js

# ─────────────────────────────────────────────────────────────
